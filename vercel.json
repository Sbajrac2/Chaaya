{
  "buildCommand": "pnpm --filter @workspace/api-server build && pnpm --filter @workspace/aasha build",
  "outputDirectory": "artifacts/aasha/dist/public",
  "installCommand": "pnpm install",
  "functions": {
    "api/index.mjs": {
      "includeFiles": "artifacts/api-server/dist/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" }
  ]
}
